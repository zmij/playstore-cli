{
  "name": "playstore-cli",
  "version": "1.0.0",
  "description": "CLI + MCP server for managing Google Play Console metadata, screenshots, in-app products, and subscriptions",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "playstore": "./build/index.js",
    "playstore-mcp": "./build/mcp/server.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "npm run build && npm run start",
    "watch": "tsc --watch",
    "docs:llms": "node scripts/build-llms-full.mjs",
    "docs:dev": "npm run docs:llms && vitepress dev docs",
    "docs:build": "npm run docs:llms && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "playstore",
    "google-play",
    "android",
    "metadata",
    "screenshots",
    "iap",
    "subscriptions",
    "mcp"
  ],
  "author": "Sergei Fedorov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zmij/playstore-cli.git"
  },
  "bugs": {
    "url": "https://github.com/zmij/playstore-cli/issues"
  },
  "homepage": "https://github.com/zmij/playstore-cli#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "googleapis": "^173.0.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitepress": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
